{% extends 'base.html.twig' %}

{% block title %}{{'task.list'|trans}}{% endblock %}

{% block body %}
<div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="h4 fw-bold mb-0">{{ 'task.list'|trans }}</h1>
    <a href="{{ path('app_task_new') }}" class="btn btn-dark btn-sm d-inline-flex align-items-center gap-2">
        <i class="bi bi-plus-lg"></i>{{ 'task.new'|trans }}
    </a>
</div>
<div class="card border-0 shadow-sm rounded-3 overflow-hidden">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th class="fw-semibold">{{'task.title'|trans}}</th>
                <th class="fw-semibold">{{'task.description'|trans}}</th>
                <th class="fw-semibold">{{'task.status'|trans}}</th>
                <th class="fw-semibold">{{'task.deadline'|trans}}</th>
                <th class="fw-semibold">{{'task.actions'|trans}}</th>
            </tr>
        </thead>
        <tbody>
            {% for task in tasks %}
            <tr>
                <td class="fw-medium">{{ task.title }}</td>
                <td class="text-muted small">{{ task.description }}</td>
                <td>
                    <span class="badge rounded-pill bg-secondary">
                        {{('task_status.'~ task.status.value ~'.label')|trans}}
                    </span>
                </td>

                <td class="text-muted small">
                    {% if task.deadline %}
                    <i class="bi bi-calendar3 me-1"></i>{{ task.deadline|date('d/m/Y') }}
                    {% endif %}
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_task_show', {'id': task.id}) }}"
                            class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1">
                            <i class="bi bi-eye"></i>{{ 'form.detail'|trans }}
                        </a>
                        <a href="{{ path('app_task_edit', {'id': task.id}) }}"
                            class="btn btn-outline-dark btn-sm d-inline-flex align-items-center gap-1">
                            <i class="bi bi-pencil"></i>{{ 'form.update'|trans }}
                        </a>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="text-center text-muted py-5">
                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                    {{ 'task.list.not'|trans }}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}