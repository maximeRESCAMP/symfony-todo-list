{% extends 'base.html.twig' %}

{% block title %}
{{'task.detail'|trans}} {{ task.title }}
{% endblock %}


{% block body %}
<div class="d-flex align-items-center justify-content-between mb-4">
	<h1 class="h4 fw-bold mb-0">{{ 'task.detail'|trans }} {{ task.title }}</h1>
	<a href="{{ path('app_task_index') }}"
		class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-2">
		<i class="bi bi-arrow-left"></i>{{ 'task.back_page'|trans }}
	</a>
</div>
<div class="card border-0 shadow-sm rounded-3 overflow-hidden mb-3">
	<table class="table align-middle mb-0">
		<tbody>
			<tr>
				<th class="table-light fw-semibold w-25">{{'task.title'|trans}}</th>
				<td>{{ task.title }}</td>
			</tr>
			<tr>
				<th class="table-light fw-semibold">{{'task.description'|trans}}</th>
				<td class="text-muted small">{{ task.description }}</td>
			</tr>
			<tr>
				<th class="table-light fw-semibold">{{'task.status'|trans}}</th>
				<td>
					<span class="badge rounded-pill bg-secondary">
						{{ task.status.value }}
					</span>
				</td>
			</tr>
			<tr>
				<th class="table-light fw-semibold">{{ 'task.deadline'|trans }}</th>
				<td class="text-muted small">
					{% if task.deadline %}
					<i class="bi bi-calendar3 me-1"></i>{{ task.deadline|date('d/m/Y') }}
					{% endif %}
				</td>
			</tr>
		</tbody>
	</table>
</div>


<div class="d-flex justify-content-end gap-2">
	<a href="{{ path('app_task_edit', {'id': task.id}) }}"
		class="btn btn-dark btn-sm d-inline-flex align-items-center gap-2">
		<i class="bi bi-pencil"></i>{{ 'task.update'|trans }}
	</a>
	{{ include('task/_delete_form.html.twig') }}
</div>

{% endblock %}